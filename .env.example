# Informações do Aplicativo
APP_NAME=LoadStock
APP_SUBTITLE=Sistema PDV Moderno
APP_VERSION=1.0.0

# Assets
LOGO_PATH=assets/logo/logo.svg
LOGO_ICON=S

# API Configuration
API_BASE_URL=http://localhost:8000/api
API_TIMEOUT=30000

# Autenticação
AUTH_TOKEN_KEY=auth_token
AUTH_USER_KEY=user_data
AUTH_REFRESH_TOKEN_KEY=refresh_token

# Storage Keys
THEME_KEY=theme_mode
LANGUAGE_KEY=language
FIRST_RUN_KEY=first_run

# Cores do Tema (Hex)
PRIMARY_COLOR=0xFF2563EB
SECONDARY_COLOR=0xFF3B82F6
ACCENT_COLOR=0xFF10B981
ERROR_COLOR=0xFFEF4444
WARNING_COLOR=0xFFF59E0B
SUCCESS_COLOR=0xFF10B981

# Configurações de Desenvolvimento
DEBUG_MODE=true
ENABLE_LOGS=true
